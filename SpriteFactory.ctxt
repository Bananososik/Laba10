comment13.text=\n\ \u0421\u0442\u0435\u043D\u0430\ \u0432\ \u0441\u0442\u0438\u043B\u0435\ \u043E\u0431\u0448\u0438\u0432\u043A\u0438\ \u043A\u043E\u0441\u043C\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E\ \u043A\u043E\u0440\u0430\u0431\u043B\u044F.\ \u041C\u0435\u0442\u0430\u043B\u043B\u0438\u0447\u0435\u0441\u043A\u0438\u0435\ \u043F\u0430\u043D\u0435\u043B\u0438,\n\ \u0437\u0430\u043A\u043B\u0451\u043F\u043A\u0438,\ \u0440\u0451\u0431\u0440\u0430\ \u0436\u0451\u0441\u0442\u043A\u043E\u0441\u0442\u0438\ \u0438\ \u043F\u043E\u0434\u0441\u0432\u0435\u0442\u043A\u0430\ \u0448\u0432\u043E\u0432.\ \u0412\u0430\u0440\u0438\u0430\u043D\u0442\ \u0432\u043B\u0438\u044F\u0435\u0442\ \u043D\u0430\ \u0430\u043A\u0446\u0435\u043D\u0442\ \u0433\u0440\u0430\u043D\u0438.\n
